#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
VENV_PY="$SCRIPT_DIR/.venv/bin/python"

# Ensure local package imports work even when launched outside repo cwd.
cd "$SCRIPT_DIR"

if [ -x "$VENV_PY" ]; then
  exec "$VENV_PY" -m restore_batch "$@"
fi

exec python3 -m restore_batch "$@"
